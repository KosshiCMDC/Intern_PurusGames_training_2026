class UIGame{
    constructor(context,canvas,x,y,width,height){
        this.context = context;
        this.canvas = canvas;
        this.x =x;
        this.y = y;
        this.width = width;
        this.height = height;
    }
}

class Score extends UIGame{
    static ScoreBoardUI;
    constructor(context,canvas,x,y,width,height){
        super(context,canvas,x,y,width,height)
        this.score =0;
        this.loadImage();
    }
    setScore(score){
        this.score += score;
    }
    loadImage(){
        Score.ScoreBoardUI = new Image();
        Score.ScoreBoardUI.src = 'assetGame/scoreBoard.png';
    }
    draw(){
        let UIwidth = this.width;
        let UIheight = Score.ScoreBoardUI.height * (this.width/Score.ScoreBoardUI.width);
        let posX = this.canvas.width/2 - UIwidth/2;
        this.context.drawImage(Score.ScoreBoardUI,
            posX,
            50,
            UIwidth,
            UIheight
        )
        this.context.save();
        this.context.beginPath();
        this.context.fillstyle = "black";
        this.context.font = 'bold 25px Arial';
        this.context.textAlign = 'center';
        this.context.textBaseline = "middle";
        this.context.fillText(this.score,this.canvas.width/2,45+this.height/2);
        
        this.context.restore();
    }
}

class startButton extends UIGame{
    static startButtonUI;
    constructor(context,canvas,width,height){
        super(context,canvas,0,0,width,height);
        this.posX = this.canvas.width/2 - this.width/2;
        this.posY = this.canvas.height/2 - this.height/2+100;
        this.loadImage()
    }
    loadImage(){
        startButton.startButtonUI = new Image();
        startButton.startButtonUI.src = 'assetGame/button.png';
    }
    draw(){
        this.context.imageSmoothingEnabled = false;
        this.buttonWidth = this.width;
        this.buttonHeight = startButton.startButtonUI.height * (this.width/startButton.startButtonUI.width);

        this.context.drawImage(startButton.startButtonUI, 
            this.posX,
            this.posY,
            this.buttonWidth,
            this.buttonHeight
        );

        this.context.save();
        this.context.fillStyle = "orange";
        this.context.textAlign = 'center';
        this.context.font = 'bold 35px Arial'
        this.context.fillText("!FLAPPY FISH!",this.canvas.width/2,100);

        this.context.beginPath();
        this.context.textAlign = 'center';
        this.context.textBaseline = 'middle';
        this.context.font = '25px Arial';
        this.context.fillText('!START!',this.canvas.width/2,this.posY+this.buttonHeight/2);
        this.context.restore();
    }
    isMouseTouch(mouseX,mouseY){
        return mouseX > this.posX && 
                mouseX < this.posX+this.width &&
                mouseY > this.posY &&
                mouseY < this.posY+this.buttonHeight;
    }
}
